document.addEventListener('DOMContentLoaded',()=>{try{const d=safeData();renderKpis('#kpis',d.kpis);populateSelect('#filter-region',d.filters.regions);populateSelect('#filter-sexe',d.filters.sexes);populateSelect('#filter-residence',d.filters.residences);populateSelect('#filter-dataset',d.filters.datasets);['#filter-region','#filter-sexe','#filter-residence','#filter-dataset'].forEach(id=>$(id)?.addEventListener('change',updateGender));updateHome();updateGender();updateOrgs();$('#download-filtered')?.addEventListener('click',()=>csvDownload('respondants_filtres.csv',filteredRespondents()));}catch(e){console.error(e);document.body.insertAdjacentHTML('afterbegin',`<div class="callout">Erreur de chargement des données : ${e.message}</div>`)}});
function updateHome(){const d=safeData();if($('#regions-list'))$('#regions-list').innerHTML=d.counts.regions.map(r=>`<span class="pill">${r}</span>`).join(' ');if($('#source-note'))$('#source-note').textContent=d.meta.note;}
function updateGender(){if(!$('#gender-table'))return;const rows=filteredRespondents();drawBar('#chart-region',countBy(rows,'region').slice(0,10),'Répondant.e.s');drawDonut('#chart-sex',countBy(rows,'sexe'),'Sexe');drawBar('#chart-education',countBy(rows,'niveau_instruction').slice(0,12),'Niveau d’instruction');drawDonut('#chart-residence',countBy(rows,'statut_residence'),'Statut de résidence');const sample=rows.slice(0,300).map(r=>({dataset:r.dataset,region:r.region,sexe:r.sexe,age:r.age,statut_residence:r.statut_residence,niveau_instruction:r.niveau_instruction,handicap:r.handicap,completude_pct:r.completude_pct}));table('#gender-table',sample,[{key:'dataset',label:'Dataset'},{key:'region',label:'Région'},{key:'sexe',label:'Sexe'},{key:'age',label:'Âge'},{key:'statut_residence',label:'Statut'},{key:'niveau_instruction',label:'Instruction'},{key:'handicap',label:'Handicap'},{key:'completude_pct',label:'Complétude',format:v=>pct(v)}]);const n=$('#filtered-count');if(n)n.textContent=fmt(rows.length)}
function updateOrgs(){if(!$('#org-table'))return;const d=safeData();const orgs=d.organisations||[];drawDonut('#chart-org-fin',countBy(orgs,'financement_humanitaire'),'Financement');drawDonut('#chart-org-coord',countBy(orgs,'participation_coordination'),'Coordination');drawBar('#chart-org-satisfaction',countBy(orgs,'satisfaction_coordination').slice(0,10),'Satisfaction');table('#org-table',orgs,[{key:'type_organisation',label:'Type'},{key:'financement_humanitaire',label:'Financement'},{key:'connaissance_coordination',label:'Connaissance coordination'},{key:'participation_coordination',label:'Participation coordination'},{key:'satisfaction_coordination',label:'Satisfaction'},{key:'completude_pct',label:'Complétude',format:v=>pct(v)}]);const n=$('#org-count');if(n)n.textContent=fmt(orgs.length)}
